# postgres
PG_IMAGE=postgres:14.13-alpine
PG_DATABASE=postgres
PG_USER=postgres
PG_PASSWORD=postgres
PG_PORT=6432
PG_TZ=UTC

# kafka-ui
KAFKAUI_IMAGE=provectuslabs/kafka-ui:v0.7.2
KAFKAUI_PORT=8000
KAFKA_CLUSTERS_0_NAME=
KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS=
KAFKA_CLUSTERS_1_NAME=
KAFKA_CLUSTERS_1_BOOTSTRAPSERVERS=
KAFKA_CLUSTERS_2_NAME=
KAFKA_CLUSTERS_2_BOOTSTRAPSERVERS=

# n8n
N8N_IMAGE=n8nio/n8n:1.123.28
NODE_ENV=production
N8N_HOST=localhost.n8n
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=wAbu?!8T+Gzw%Q2c
N8N_POSTGRES_DATABASE=n8n
N8N_DB_TYPE=postgresdb
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# n8n postgre
N8N_POSTGRES_IMAGE=bitnami/postgresql:17.5.0
N8N_POSTGRES_USER=
N8N_POSTGRES_PASSWORD=
N8N_POSTGRES_PORT=
N8N_POSTGRES_TIMEZONE=Asia/Jakarta

# n8n runner
N8N_RUNNERS_ENABLED=true
N8N_RUNNERS_MODE=external
N8N_RUNNERS_AUTH_TOKEN=qFb4B6g3H7jK9lM2nO4pQ6sR8uT0wZ3xY5vB7nJ9m
N8N_RUNNER_IMAGE=n8nio/runners:1.123.28
N8N_RUNNERS_HOST=n8n
N8N_RUNNERS_PORT=5679

# apache kafka
APACHE_KAFKA_IMAGE=apache/kafka:3.8.1

# rabbitmq
RABBIT_IMAGE=rabbitmq:4.0.4-management-alpine

# redis
REDIS_IMAGE=redis:8.4.0-alpine3.22

# nginx
