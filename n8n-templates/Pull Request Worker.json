    {
      "parameters": {
        "jsCode": "const myUserLoginID = 'kcchandra-w6'\nlet reviews = $input.all()\n\nconst idx = parseInt($runIndex.toString())\nconst pr_data = $('Need Review').all()[idx]\nconst data = pr_data.json.data\n\nconst result = {\n  valid: true,\n  repo_name: data.head.repo.name,\n  pr_html_link: data.html_url,\n  pr_number: data.number\n}\n\nif (data.user.login == myUserLoginID) { // myself\n  result.valid = false\n  return result\n}\n\nif (reviews.length == 1 && \n    Object.keys(reviews[0].json).length == 0) {\n  return result\n}\n\nconst currentDate = new Date()\nfor (const rev of reviews) {\n  const item = rev.json\n\n  if (Object.keys(item).length == 0) {\n    continue\n  }\n  \n  if (item.user?.login !== myUserLoginID) {\n    continue\n  }\n\n  const isApproved = item.state === 'APPROVED'\n  const isReqChanges = item.state === 'CHANGES_REQUESTED'\n  \n  if (isApproved || isReqChanges) {\n    result.valid = false\n    return result\n  }\n\n  if (item.body.includes('postpone')) {\n    const bodies = item.body.split(' ') || []\n    if (bodies.length !== 2) {\n      continue\n    }\n    \n    const postponeDateUnix = Date.parse(bodies[1])\n    if (isNaN(postponeDateUnix)) {\n      continue\n    }\n\n    const diff = currentDate.getTime() - postponeDateUnix\n    if (diff <= 0) {\n      result.valid = false\n      return result\n    }\n  }\n}\n\nreturn result;"
      },
