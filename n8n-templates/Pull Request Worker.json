    {
      "parameters": {
        "jsCode": "let filterredData = $input.all()\nlet pullRequestLink= Array()\n\nfilterredData.forEach((val) => {\n  let data = val.json\n  const repoName = data.repo_name\n  const link = data.pr_html_link\n  const prNumber = data.pr_number\n  pullRequestLink.push(`- <${link}|${repoName} [PR ${prNumber}]>`)\n})\n\nlet combined = pullRequestLink.join('\\n')\n\nreturn {\n  total_data: pullRequestLink.length,\n  msg: combined\n}"
      },
