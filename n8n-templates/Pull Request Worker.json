    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const TYPE_NEED_REVIEW = 'need_review'\nconst TYPE_AUTO_APPROVE = 'auto_approve'\nconst TYPE_IGNORE = 'ignore'\n\nlet errMessage = $json.error || \"\"\nif (errMessage != \"\") {\n  return {\n    data: $json,\n    type: 'error',\n    error: errMessage\n  }\n}\n\nlet ref = $json.head.ref // branch name - source branch\nlet baseRef = $json.base.ref // branch name - target branch\nlet myUserLogin = 'kcchandra-w6'\n\nif (baseRef == 'master') {\n  return {\n    data: $json,\n    type: TYPE_AUTO_APPROVE\n  }\n}\n\n// Urgent Auto \nfor (const label of $json.labels) {\n  if (label.name == 'help wanted') {\n    return {\n      data: $json,\n      type: TYPE_AUTO_APPROVE\n    }\n  }\n}\n\n// PR created by ME\nif ($json.user.login == myUserLogin) {\n  return {\n    data: $json,\n    type: TYPE_IGNORE\n  }\n}\n\nconst validBaseBranch = baseRef.startsWith('test01/') || baseRef.startsWith('rs/') || baseRef.startsWith('urgent/')\nconst validPullBranch = ref.startsWith('feature/') || ref.startsWith('test01/') || ref.startsWith('rs/')\nif (validBaseBranch && validPullBranch) {\n  return {\n    data: $json,\n    type: TYPE_AUTO_APPROVE\n  }\n}\n\nconst validBaseBranchNeedReview = baseRef.startsWith('feature/') || baseRef.startsWith('feat/') || baseRef.startsWith('chore/') || baseRef.startsWith('fix/') || baseRef.startsWith('feature/') \nif (validBaseBranchNeedReview) {\n  return {\n    data: $json,\n    type: TYPE_NEED_REVIEW\n  }\n}\n\nreturn {\n  data: $json,\n  type: TYPE_IGNORE\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
